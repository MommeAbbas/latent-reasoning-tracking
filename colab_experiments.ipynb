    "## 2. ROC Figure — real filter outputs, 10 seeds\n",
    "\n",
    "This is the main Figure 1. Replaces the fabricated version."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import roc_curve, auc as sk_auc\n",
    "\n",
    "from src.evaluation.run_simulation_eval import run_eval\n",
    "\n",
    "N_SEEDS = 10\n",
    "N_TRAJ  = 150\n",
    "T       = 35\n",
    "EARLY_K = 4\n",
    "BASE_FPR = np.linspace(0, 1, 101)\n",
    "\n",
    "tprs = {name: [] for name in ['RBPF', 'EKF', 'PF']}\n",
    "aucs = {name: [] for name in ['RBPF', 'EKF', 'PF']}\n",
    "\n",
    "for seed in range(N_SEEDS):\n",
    "    print(f'Seed {seed+1}/{N_SEEDS} ...', end=' ')\n",
    "    preds_rbpf, preds_ekf, preds_pf, labels = run_eval(\n",
    "        seed=seed, N_traj=N_TRAJ, T=T, PARTICLES=125, verbose=False\n",
    "    )\n",
    "    print(f'class balance: {labels.mean()*100:.0f}% positive')\n",
    "\n",
    "    if len(np.unique(labels)) < 2:\n",
    "        print('  skipping (one class)')\n",
    "        continue\n",
    "\n",
    "    for name, preds in [('RBPF', preds_rbpf), ('EKF', preds_ekf), ('PF', preds_pf)]:\n",
    "        scores = preds[:, -1]   # final-step predictions\n",
    "        fpr, tpr, _ = roc_curve(labels, scores)\n",
    "        tpr_i = np.interp(BASE_FPR, fpr, tpr)\n",
    "        tpr_i[0] = 0.0\n",
    "        tprs[name].append(tpr_i)\n",
    "        aucs[name].append(sk_auc(BASE_FPR, tpr_i))\n",
    "\n",
    "# Print results\n",
    "print('\\n=== ROC Results (final step) ===')\n",
    "for name in ['RBPF', 'PF', 'EKF']:\n",
    "    a = np.array(aucs[name])\n",
    "    print(f'{name}: AUC = {a.mean():.3f} ± {a.std():.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot\n",
    "plt.rcParams.update({'font.size': 12, 'font.family': 'serif'})\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "\n",
    "colors = {'RBPF': '#004488', 'PF': '#DDAA33', 'EKF': '#BB5566'}\n",
    "styles = {'RBPF': '-',       'PF': '--',      'EKF': '-.'}\n",
    "\n",
    "for name in ['RBPF', 'PF', 'EKF']:\n",
    "    arr = np.array(tprs[name])\n",
    "    mean_tpr, std_tpr = arr.mean(0), arr.std(0)\n",
    "    mean_auc = np.array(aucs[name]).mean()\n",
    "    std_auc  = np.array(aucs[name]).std()\n",
    "    ax.plot(BASE_FPR, mean_tpr, color=colors[name], lw=2,\n",
    "            ls=styles[name], label=f'{name} AUC={mean_auc:.2f}±{std_auc:.2f}')\n",
    "    ax.fill_between(BASE_FPR,\n",
    "                    np.clip(mean_tpr - std_tpr, 0, 1),\n",
    "                    np.clip(mean_tpr + std_tpr, 0, 1),\n",
    "                    color=colors[name], alpha=0.2)\n",
    "\n",
    "ax.plot([0,1],[0,1],'k:',lw=1)\n",
    "ax.set_xlabel('False Positive Rate'); ax.set_ylabel('True Positive Rate')\n",
    "ax.set_title('Early Success Prediction (SLDS Simulation)')\n",
    "ax.legend(loc='lower right')\n",
    "plt.tight_layout()\n",
    "\n",
    "import os; os.makedirs('figures', exist_ok=True)\n",
    "plt.savefig('figures/fig_roc_early_prediction.png', dpi=300)\n",
    "plt.show()\n",
    "print('Saved figures/fig_roc_early_prediction.png')"
   ]
  },
